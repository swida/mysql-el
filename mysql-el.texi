@node MySQL Complete Example
@section A Complete Example
@cindex example, MySQL

  The following example demonstrates how to use the MySQL module to
manage a simple employee table.  It exercises all the core @acronym{API}
functions in sequence: connecting, creating a table, inserting data
(with and without bind parameters), querying, updating, using
transactions, batch execution, and closing the connection.

@lisp
;; Load the module.
(module-load "/path/to/mysql-el.so")

;; Connect to a MySQL server.
(setq db (mysql-open "127.0.0.1" "root" "" "mydb" 3306))

;; Create a table.
(mysql-execute db
  "CREATE TABLE employees (
     id     INT PRIMARY KEY AUTO_INCREMENT,
     name   VARCHAR(100) NOT NULL,
     dept   VARCHAR(50),
     salary DOUBLE
   ) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4")

;; Insert rows using plain SQL.
(mysql-execute db
  "INSERT INTO employees (name, dept, salary)
   VALUES ('Alice', 'Engineering', 95000)")
    @result{} 1

;; Insert a row using bind parameters (safer, prevents injection).
(mysql-execute db
  "INSERT INTO employees (name, dept, salary) VALUES (?, ?, ?)"
  '("Bob" "Product" 88000.0))
    @result{} 1

;; Query all employees.
(mysql-select db
  "SELECT name, dept, salary FROM employees ORDER BY id")
    @result{} (("Alice" "Engineering" 95000.0)
        ("Bob" "Product" 88000.0))

;; Query with column names (full mode).
(mysql-select db
  "SELECT name, salary FROM employees" nil 'full)
    @result{} (("name" "salary")
        ("Alice" 95000.0)
        ("Bob" 88000.0))

;; Conditional query with bind parameters.
(mysql-select db
  "SELECT name FROM employees WHERE dept = ?"
  '("Engineering"))
    @result{} (("Alice"))

;; Update rows; returns number of changed rows.
(mysql-execute db
  "UPDATE employees SET salary = salary * 1.1
   WHERE dept = 'Engineering'")
    @result{} 1

;; Use a transaction to insert multiple rows atomically.
(mysql-transaction db)
(mysql-execute db
  "INSERT INTO employees (name, dept, salary) VALUES (?, ?, ?)"
  '("Carol" "Engineering" 92000.0))
(mysql-execute db
  "INSERT INTO employees (name, dept, salary) VALUES (?, ?, ?)"
  '("Dave" "Finance" 78000.0))
(mysql-commit db)

;; Batch-execute multiple statements.
(mysql-execute-batch db
  "INSERT INTO employees (name, dept, salary)
     VALUES ('Eve', 'HR', 70000);
   INSERT INTO employees (name, dept, salary)
     VALUES ('Frank', 'HR', 72000);")
    @result{} t

;; Iterate over a large result set lazily with a set object.
(let ((set (mysql-select db
              "SELECT name, salary FROM employees ORDER BY id"
              nil 'set)))
  (unwind-protect
      (progn
        ;; Get column names.
        (mysql-columns set)
            @result{} ("name" "salary")
        ;; Fetch rows one by one.
        (while (mysql-more-p set)
          (let ((row (mysql-next set)))
            (when row
              (message "Employee: %s, salary: %s"
                       (nth 0 row) (nth 1 row))))))
    (mysql-finalize set)))

;; Clean up and close.
(mysql-execute db "DROP TABLE employees")
(mysql-close db)
@end lisp

@bye
